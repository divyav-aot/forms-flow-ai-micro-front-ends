import { Components } from 'formiojs';

const FieldComponent = Components.components.field;

export default class RSBCImage extends FieldComponent {
  static schema(...extend) {
    return FieldComponent.schema({
      type: 'rsbcimage',
      label: 'RSBC Image',
      key: 'rsbcImage',
      ...extend,
    });
  }

  static get builderInfo() {
    return {
      title: 'RSBC Image',
      group: 'basic',
      icon: 'image',
      weight: 70,
      schema: RSBCImage.schema(),
    };
  }

  render() {
    return `
      <div class="rsbc-image-container">
        <div class="rsbc-image">${this.builderMode ? 'RSBC Printing Images' : 'Loading images...'}</div>
      </div>
    `;
  }

  attach(element) {
    const result = super.attach(element);

    // Ensure we get the correct container
    const imageContainer = element.querySelector('.rsbc-image');
    if (!imageContainer) {
      console.error('RSBCImage: Image container not found.');
      return result;
    }

    if (this.builderMode) {
      // Show a placeholder in Form Builder Mode
      imageContainer.innerHTML = 'RSBC Printing Images';
    } else {
      // Load images dynamically in Submit Mode
      this.loadImages(imageContainer);
    }

    return result;
  }

  loadImages(container) {
    try {
      if (!window.printServices || typeof window.printServices.renderSVGForm !== 'function') {
        console.error('RSBCImage: printServices.renderSVGForm is not available.');
        container.innerHTML = '<div>Error: Cannot load images.</div>';
        return;
      }

      const result = window.printServices.renderSVGForm('', '');
      if (Array.isArray(result)) {
        console.log('renderSVGForm count:', result.length);

        // Convert images into HTML and insert them into the container
        container.innerHTML = result.map((image, index) => `<div key="${index}">${image}</div>`).join('');
      } else {
        console.warn('renderSVGForm did not return an array:', result);
        container.innerHTML = '<div>No images to display</div>';
      }
    } catch (error) {
      console.error('Error calling renderSVGForm:', error);
      container.innerHTML = '<div>Error loading images</div>';
    }
  }
}

// Register the custom component in Form.io
//Components.addComponent('rsbcimage', RSBCImage);
